# Launchpad Solutions — environment variables
# Copy this file to .env.local (gitignored) and fill in real values for local dev.

# Base URL of the deployed site. Used for sitemap, RSS, canonical URLs.
# In Vercel production, set to https://launchpadsolutions.ca
NEXT_PUBLIC_SITE_URL=https://launchpadsolutions.ca

# Mailchimp embedded form action URL.
# Get this from Mailchimp -> Audience -> Signup forms -> Embedded forms.
# Copy the <form action="..."> value; the "/post?u=...&id=..." URL.
# Leave blank during initial rollout to use optimistic UX without real submission.
NEXT_PUBLIC_MAILCHIMP_URL=
